{
  "expo": {
    "name": "dub-ai-tracker",
    "slug": "dub-ai-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "dub-ai-tracker",
    "sdkVersion": "55.0.0",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E2761"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soledgerai.dubaitracker",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "DUB_AI reads your health data (steps, workouts, sleep, heart rate) to provide personalized wellness coaching and tracking.",
        "NSHealthUpdateUsageDescription": "DUB_AI writes workout and nutrition summaries to Apple Health so your data stays in sync across health apps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.soledgerai.dubaitracker",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b88960a-8aa4-4872-bd3c-93f03cea249f"
      }
    }
  }
}
