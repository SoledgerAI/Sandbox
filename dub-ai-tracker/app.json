{
  "expo": {
    "name": "DUB Tracker",
    "slug": "dub-ai-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/dub_app_icon_1024.png",
    "userInterfaceStyle": "dark",
    "scheme": ["dub-ai-tracker", "dubaitracker"],
    "sdkVersion": "55.0.0",
    "splash": {
      "image": "./assets/dub_splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0D0F1A"
    },
    "ios": {
      "icon": "./assets/dub_app_icon_1024.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.soledgerai.dubaitracker",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "DUB_AI uses Face ID to protect your health data and app access.",
        "NSCameraUsageDescription": "DUB uses your camera to photograph meals for your food log.",
        "NSPhotoLibraryUsageDescription": "DUB accesses your photo library to attach meal photos.",
        "NSHealthShareUsageDescription": "DUB_AI reads your health data (steps, workouts, sleep, heart rate) to provide personalized wellness coaching and tracking.",
        "NSHealthUpdateUsageDescription": "DUB_AI writes workout and nutrition summaries to Apple Health so your data stays in sync across health apps.",
        "NSUserTrackingUsageDescription": "DUB_AI requests permission to track affiliate link interactions to improve product recommendations."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeHealthInfo",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhotosorVideos",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          }
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.soledgerai.dubaitracker",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/exclude-from-backup",
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-local-authentication",
      "expo-image-picker",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1E2761"
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "DUB_AI requests permission to track affiliate link interactions to improve product recommendations."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b88960a-8aa4-4872-bd3c-93f03cea249f"
      }
    },
    "owner": "soledgerai"
  }
}
