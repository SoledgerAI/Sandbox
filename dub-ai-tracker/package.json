{
  "name": "dub-ai-tracker",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-pre-install": "npm config set legacy-peer-deps true",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "setupFilesAfterEnv": [
      "./jest.setup.afterenv.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|react-native-reanimated|react-native-gesture-handler|react-native-health|react-native-health-connect|react-native-aes-crypto|@react-native-async-storage/async-storage)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "expo": "~55.0.9",
    "expo-camera": "~55.0.11",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-file-system": "~55.0.12",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.14",
    "expo-linking": "~55.0.9",
    "expo-notifications": "~55.0.14",
    "expo-print": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-secure-store": "~55.0.9",
    "expo-sharing": "~55.0.14",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-aes-crypto": "^3.3.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-health": "^1.18.0",
    "react-native-health-connect": "^3.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.11",
    "react-native-worklets": "0.7.2",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-health",
          "react-native-aes-crypto"
        ]
      }
    }
  },
  "overrides": {
    "@expo/log-box": "55.0.3"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
